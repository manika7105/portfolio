# Get a free API key at https://resend.com after signing up.
RESEND_API_KEY=your_resend_api_key_here

# Email address that receives contact-form submissions.
CONTACT_TO_EMAIL=goelmanika07@gmail.com

# Sender address. Resend's shared "onboarding@resend.dev" works without any
# setup. Once you verify your own domain on resend.com, switch to an address
# on that domain (e.g. contact@yourdomain.com) for better deliverability.
CONTACT_FROM_EMAIL=onboarding@resend.dev
